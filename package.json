{
  "name": "slowpoke",
  "version": "0.1.0",
  "description": "A Discord bot written in TypeScript - converted from Rust",
  "packageManager": "pnpm@10.28.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "clean": "rm -rf dist",
    "codex:auth:login": "langchainjs-codex-oauth auth login",
    "codex:auth:logout": "langchainjs-codex-oauth auth logout",
    "codex:auth:status": "langchainjs-codex-oauth auth status",
    "prebuild": "pnpm run clean && pnpm run lint",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "discord",
    "bot",
    "typescript"
  ],
  "author": "Jeph",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@langchain/classic": "^1.0.32",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.42",
    "@langchain/textsplitters": "^1.0.1",
    "cheerio": "^1.2.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "langchain": "^1.3.5",
    "langchainjs-codex-oauth": "^0.1.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
